{
  "schema": "prog.lens_manifest",
  "id": "npm-test",
  "match": {"source_kind": "cli", "source_id": "run", "operation": "npm", "artifact_kind": "run"},
  "view": {"limit": 8, "depth": 4, "fields": {"command": "/command", "failures": "/failure_sections", "stderr": "/stderr/head", "stdout": "/stdout/head"}},
  "omit": [
    {"path": "/stderr/text", "reason": "large_string", "detail": "full npm diagnostics remain cursor-expandable", "expandable": true},
    {"path": "/stdout/text", "reason": "large_string", "detail": "full test output remains cursor-expandable", "expandable": true}
  ],
  "findings": [
    {"kind": "npm_test_failure", "path": "/failure_sections/*", "confidence": 0.96, "reason": "npm test failure section contains captured error evidence", "title": "npm test failure", "severity": "error"}
  ],
  "next_actions": [{"kind": "evidence", "path": "/failure_sections/0", "reason": "cite the first npm test failure"}],
  "invariants": ["stack_text_is_not_duplicated_in_findings", "full_streams_remain_expandable", "redaction_precedes_lens_projection"],
  "fixtures": {"positive": ["fixtures/npm-test-run.json"], "negative": ["fixtures/counterexamples/json-items.json"]}
}
